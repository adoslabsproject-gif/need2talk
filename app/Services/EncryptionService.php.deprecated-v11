    /**
     * Validate encryption key format
     *
     * @param string $keyBase64 Base64-encoded key
     * @return bool Valid format
     */
    public function validateKeyFormat(string $keyBase64): bool
    {
        $key = base64_decode($keyBase64, true);

        if ($key === false) {
            return false;
        }

        // AES-256 key must be 32 bytes (256 bits)
        return strlen($key) === self::KEY_LENGTH;
    }

    /**
     * Clear user key cache
     * Called on logout or key rotation
     *
     * @param int $userId User ID
     */
    public function clearUserKeyCache(int $userId): void
    {
        $cacheKey = "encryption_key:{$userId}";
        $this->cache->delete($cacheKey);

        Logger::debug('User encryption key cache cleared', ['user_id' => $userId]);
    }

    /**
     * Get encryption statistics for monitoring
     *
     * @return array Statistics
     */
    public function getStatistics(): array
    {
        $db = db();

        try {
            $stats = $db->findOne(
                "SELECT
                    COUNT(*) as total_keys,
                    AVG(key_version) as avg_key_version,
                    MAX(key_version) as max_key_version,
                    COUNT(CASE WHEN last_rotated_at IS NOT NULL THEN 1 END) as rotated_keys_count
                 FROM user_encryption_keys",
                [],
                ['cache' => true, 'cache_ttl' => 'medium']
            );

            return [
                'total_keys' => (int) $stats['total_keys'],
                'avg_key_version' => round((float) $stats['avg_key_version'], 2),
                'max_key_version' => (int) $stats['max_key_version'],
                'rotated_keys_count' => (int) $stats['rotated_keys_count'],
            ];

        } catch (\Exception $e) {
            Logger::error('Failed to fetch encryption statistics', ['error' => $e->getMessage()]);

            return [
                'total_keys' => 0,
                'avg_key_version' => 0,
                'max_key_version' => 0,
                'rotated_keys_count' => 0,
            ];
        }
    }

    /**
     * ENTERPRISE V10.72: Decode PostgreSQL BYTEA value to raw binary
     *
     * PostgreSQL PDO returns BYTEA in different formats depending on bytea_output setting:
     * - 'hex' (default): Returns '\x' followed by hex digits (e.g., '\x48454c4c4f')
     * - 'escape': Returns traditional PostgreSQL escape format
     *
     * This method handles both formats transparently.
     *
     * @param string|resource $value BYTEA value from PDO
     * @return string Raw binary data
     */
    private function decodeBytea(mixed $value): string
    {
        // Handle stream resource (PDO::PARAM_LOB case)
        if (is_resource($value)) {
            $value = stream_get_contents($value);
        }

        // Handle hex format: \x followed by hex digits
        if (is_string($value) && str_starts_with($value, '\\x')) {
            return hex2bin(substr($value, 2));
        }

        // Handle escaped format or raw binary (passthrough)
        return $value;
    }

