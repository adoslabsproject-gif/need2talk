/**
 * =============================================================================
 * ENCRYPTION SERVICE - SERVER-SIDE (Hybrid Zero-Knowledge)
 * =============================================================================
 *
 * ENTERPRISE GALAXY+ - Server-Side Encryption Key Management
 * Target: 100,000+ concurrent users
 * Algorithm: AES-256-GCM (FIPS 140-2 compliant)
 *
 * PURPOSE:
 * Manages user encryption keys and provides encryption utilities.
 * Hybrid approach: User data encrypted client-side, keys encrypted server-side.
 *
 * ARCHITECTURE:
 * - User Master Key: Stored encrypted at rest (AES-256-GCM)
 * - Server Master Key: Stored in environment variable (.env)
 * - Algorithm: AES-256-GCM (FIPS 140-2 compliant)
 * - Key Rotation: Supported (increments key_version)
 *
 * PERFORMANCE:
 * - Key Operations: <5ms per operation
 * - Cached Keys: Redis L1 cache (5min TTL)
 * - Bulk Operations: Batched for efficiency
 *
 * SECURITY:
 * - Server master key NEVER logged
 * - User keys encrypted at rest
 * - Audit trail for key operations
 * - Key rotation supported
 * - Constant-time operations (timing attack resistant)
 *
 * @package Need2Talk\Services
 * @version 1.0.0 - Phase 1.3
 * @date 2025-01-07
 * =============================================================================
 */
class EncryptionService
{
    private const ALGORITHM = 'aes-256-gcm';
    private const IV_LENGTH = 12; // 96 bits for GCM (recommended)
    private const TAG_LENGTH = 16; // 128 bits authentication tag
    private const KEY_LENGTH = 32; // 256 bits (32 bytes)

    private string $serverMasterKey;
    private \Need2Talk\Core\CacheManager $cache;

    /**
     * Constructor
     * Loads server master key from isolated file (preferred) or environment (fallback)
     *
     * ENTERPRISE SECURITY: Master key stored in isolated file with chmod 400
     * - Primary: /etc/need2talk/master.key (isolated, root-only)
     * - Fallback: ENCRYPTION_MASTER_KEY env var (for backwards compatibility)
     *
     * @throws \RuntimeException If master key not found or invalid
     */
    public function __construct()
    {
        // ENTERPRISE SECURITY: Load from isolated file first (chmod 400, root-only)
        $keyFile = '/etc/need2talk/master.key';

        if (file_exists($keyFile) && is_readable($keyFile)) {
            $this->serverMasterKey = trim(file_get_contents($keyFile));
            Logger::debug('Encryption master key loaded from isolated file');
        } else {
            // Fallback to environment variable (backwards compatibility)
            $this->serverMasterKey = get_env('ENCRYPTION_MASTER_KEY');
            Logger::debug('Encryption master key loaded from environment (fallback)');
        }

        if (empty($this->serverMasterKey)) {
            throw new \RuntimeException('Master key not found. Create /etc/need2talk/master.key with: openssl rand -hex 32');
        }

        // Validate key length (must be 64 hex chars = 32 bytes = 256 bits)
        if (strlen($this->serverMasterKey) !== 64) {
            throw new \RuntimeException('ENCRYPTION_MASTER_KEY must be 64 hex characters (256 bits). Current length: ' . strlen($this->serverMasterKey));
        }

        // Validate hex format
        if (!ctype_xdigit($this->serverMasterKey)) {
            throw new \RuntimeException('ENCRYPTION_MASTER_KEY must be hexadecimal');
        }

        $this->cache = \Need2Talk\Core\EnterpriseCacheFactory::getInstance();
    }

    /**
     * Save user master key (encrypted at rest)
     *
     * FLOW:
     * 1. Receive user's master key from browser (HTTPS encrypted channel)
     * 2. Validate key format (must be 32 bytes)
     * 3. Encrypt master key with server master key (AES-256-GCM)
     * 4. Store encrypted key + IV + tag in database
     *
     * SECURITY:
     * - Key transmitted over HTTPS (encrypted channel)
     * - Key encrypted at rest with server master key
     * - Authentication tag prevents tampering
     * - Audit logged for security monitoring
     *
     * @param int $userId User ID
     * @param string $userMasterKeyBase64 Base64-encoded user master key (32 bytes)
     * @return bool Success status
     */
    public function saveUserMasterKey(int $userId, string $userMasterKeyBase64): bool
    {
        $db = db();

        try {
            // Decode user master key from base64
            $userMasterKey = base64_decode($userMasterKeyBase64, true);

            if ($userMasterKey === false || strlen($userMasterKey) !== self::KEY_LENGTH) {
                Logger::security('error', 'Invalid user master key format', [
                    'user_id' => $userId,
                    'key_length' => strlen($userMasterKey ?? ''),
                    'expected_length' => self::KEY_LENGTH,
                ]);

                return false;
            }

            // Generate random IV (CRITICAL: never reuse IVs!)
            $iv = random_bytes(self::IV_LENGTH);

            // Decrypt server master key from hex
            $serverKey = hex2bin($this->serverMasterKey);

            // Encrypt user master key with server master key (AES-256-GCM)
            $tag = ''; // Authentication tag (output parameter)
            $ciphertext = openssl_encrypt(
                $userMasterKey,
                self::ALGORITHM,
                $serverKey,
                OPENSSL_RAW_DATA,
                $iv,
                $tag
            );

            if ($ciphertext === false) {
                $opensslError = openssl_error_string();
                Logger::error('Failed to encrypt user master key', [
                    'user_id' => $userId,
                    'openssl_error' => $opensslError,
                ]);

                return false;
            }

            // Generate key derivation salt (for future PBKDF2 support)
            $kdfSalt = random_bytes(64);

            // Store encrypted key in database
            // ENTERPRISE V10.72: PostgreSQL BYTEA requires hex-encoded format via decode()
            // PDO doesn't handle binary data for BYTEA columns automatically
            // EXCLUDED contains the already-decoded BYTEA values from VALUES clause
            $sql = "INSERT INTO user_encryption_keys
                    (user_id, master_key_encrypted, master_key_iv, kdf_salt, key_version)
                    VALUES (:user_id, decode(:encrypted_key, 'hex'), decode(:iv, 'hex'), decode(:kdf_salt, 'hex'), 1)
                    ON CONFLICT (user_id) DO UPDATE SET
                        master_key_encrypted = EXCLUDED.master_key_encrypted,
                        master_key_iv = EXCLUDED.master_key_iv,
                        kdf_salt = EXCLUDED.kdf_salt,
                        key_version = user_encryption_keys.key_version + 1,
                        last_rotated_at = CURRENT_TIMESTAMP";

            $db->execute($sql, [
                'user_id' => $userId,
                'encrypted_key' => bin2hex($ciphertext . $tag), // Hex-encoded for decode()
                'iv' => bin2hex($iv),
                'kdf_salt' => bin2hex($kdfSalt),
            ], [
                'invalidate_cache' => ["encryption_key:{$userId}"],
            ]);

            // Security audit log
            Logger::security('info', 'User master key saved', [
                'user_id' => $userId,
                'key_version' => 1,
                'operation' => 'save_master_key',
            ]);

            // Clear cache
            $this->clearUserKeyCache($userId);

            return true;

        } catch (\Exception $e) {
            Logger::error('Failed to save user master key', [
                'user_id' => $userId,
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString(),
            ]);

            return false;
        }
    }

    /**
     * Load user master key (decrypted)
     *
     * PERFORMANCE: Cached in Redis L1 (5min TTL)
     * SECURITY: Decrypted key never logged
     *
     * @param int $userId User ID
     * @return string|null Base64-encoded master key or null if not exists
     */
    public function loadUserMasterKey(int $userId): ?string
    {
        $cacheKey = "encryption_key:{$userId}";

        // Try cache first (L1 Redis, 5min TTL)
        $cached = $this->cache->get($cacheKey);
        if ($cached !== null) {
            Logger::debug('Encryption key loaded from cache', ['user_id' => $userId]);

            return $cached;
        }

        // DEPRECATED: Server-side master keys removed for TRUE E2E encryption
