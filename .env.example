# ============================================================================
# need2talk.it - Environment Configuration Template
# ============================================================================
# This is a template file. Copy to .env and configure for your environment.
# .env is gitignored and contains your actual secrets.
#
# COMPLIANCE: 12 Factor App (https://12factor.net/config)
# All configuration is stored in environment variables, not in code.
# ============================================================================

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
APP_NAME="need2talk"
APP_ENV=production                  # production | staging | development
APP_DEBUG=false                     # true for development only
APP_KEY=base64:GENERATE_YOUR_KEY    # Generate with: php -r "echo base64_encode(random_bytes(32));"
APP_URL=https://example.com         # Your domain URL (no trailing slash)
APP_TIMEZONE=Europe/Rome            # PHP timezone
APP_VERSION=1.6.2

# ----------------------------------------------------------------------------
# Server Configuration (12 Factor App - Config from Environment)
# ----------------------------------------------------------------------------
# These replace hardcoded IPs in the codebase for portability
SERVER_IP=0.0.0.0                   # Production server IP (fallback when HTTP_HOST unavailable)
FALLBACK_HOST=example.com           # Fallback hostname for URL generation

# ----------------------------------------------------------------------------
# Database Configuration (PostgreSQL 16)
# ----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres                    # Docker service name or IP
DB_PORT=5432
DB_DATABASE=need2talk
DB_USERNAME=your_db_user
DB_PASSWORD=GENERATE_SECURE_PASSWORD
DB_POOL_SIZE=50                     # Connection pool size (enterprise feature)

# Database aliases (EnterpriseEnvironmentManager compatibility)
DB_NAME=need2talk
DB_USER=root

# ----------------------------------------------------------------------------
# Redis Configuration (Cache, Sessions, Queue, Rate Limiting)
# ----------------------------------------------------------------------------
REDIS_HOST=redis                    # Docker service name or IP
REDIS_PORT=6379
REDIS_PASSWORD=GENERATE_SECURE_PASSWORD
REDIS_DB_CACHE=0                    # L3 cache database
REDIS_DB_SESSION=1                  # Session storage
REDIS_DB_QUEUE=2                    # Email queue
REDIS_DB_RATE_LIMIT=3               # Rate limiting

# ----------------------------------------------------------------------------
# Memcached Configuration (L2 Cache)
# ----------------------------------------------------------------------------
MEMCACHED_HOST=memcached            # Docker service name or IP
MEMCACHED_PORT=11211

# ----------------------------------------------------------------------------
# Session Configuration
# ----------------------------------------------------------------------------
SESSION_DRIVER=redis                # redis | database | file
SESSION_LIFETIME=1440               # Session lifetime in minutes (24 hours)

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------
CACHE_DRIVER=redis                  # redis | memcached | file

# ----------------------------------------------------------------------------
# Email Configuration
# ----------------------------------------------------------------------------
# SMTP Settings (SendGrid, AWS SES, etc.)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587                       # 587 (TLS) | 465 (SSL) | 2525 (alternative)
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls                 # tls | ssl
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# SendGrid Web API (optional - for advanced features)
SENDGRID_API_KEY=your_sendgrid_api_key

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
LOG_CHANNEL=stack                   # stack | single | daily
LOG_LEVEL=error                     # debug | info | notice | warning | error | critical

# ----------------------------------------------------------------------------
# Enterprise Features
# ----------------------------------------------------------------------------
ENABLE_DEBUGBAR=false               # Enable Laravel Debugbar (development only)
ENABLE_QUERY_LOG=false              # Log all SQL queries (development only)
ENABLE_PERFORMANCE_MONITORING=true  # Performance metrics collection

# ----------------------------------------------------------------------------
# CDN Configuration - DigitalOcean Spaces (ENTERPRISE GALAXY)
# ----------------------------------------------------------------------------
# DigitalOcean Spaces (S3-compatible object storage with CDN)
# Used for: Audio streaming, photo storage, static assets
#
# SECURITY:
# - ACL: PRIVATE (objects not publicly accessible)
# - Access: AWS Signature V4 signed URLs (temporary, 1 hour expiration)
# - No hotlinking/direct access (signed URLs expire)
#
# PERFORMANCE:
# - Geographic edge locations (CDN)
# - Nginx FastCGI cache (Layer 2, 1GB RAM)
# - Redis signed URL cache (Layer 1, 1 hour TTL)
# ----------------------------------------------------------------------------

SPACES_KEY=your_spaces_access_key               # DigitalOcean Spaces Access Key
SPACES_SECRET=your_spaces_secret_key            # DigitalOcean Spaces Secret Key (KEEP SECRET!)
SPACES_BUCKET=need2talk-audio                   # Bucket name
SPACES_REGION=fra1                              # Region: fra1 (Frankfurt), nyc3 (NYC), sgp1 (Singapore)
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com  # Endpoint URL (region-specific)
SIGNED_URL_TTL=3600                             # Signed URL TTL in seconds (default: 3600 = 1 hour)

# Service Worker cache settings
SW_CACHE_MAX_SIZE_MB=100            # Maximum IndexedDB cache size
SW_CACHE_RETENTION_DAYS=7           # Cache file retention period
SW_CACHE_TARGET_HIT_RATE=95         # Target cache hit rate percentage

# ============================================================================
# SECURITY NOTES:
# ============================================================================
# 1. NEVER commit .env to Git (it's in .gitignore)
# 2. Generate strong passwords: openssl rand -base64 32
# 3. Use different credentials for each environment (dev, staging, prod)
# 4. Rotate secrets regularly (passwords, API keys)
# 5. Keep .env.example updated when adding new config options
# ============================================================================
