# 🚀 NEED2TALK - MySQL 8.0 Enterprise Configuration
# Optimized for 100,000+ concurrent users
# Performance-focused settings for social platform with messaging

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4

[mysqld]
# 🔧 Basic settings
user = mysql
default_storage_engine = InnoDB
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# 🌐 Connection settings for high concurrency
max_connections = 2000
max_user_connections = 1800
max_connect_errors = 1000000
back_log = 2048
thread_cache_size = 512
open_files_limit = 65535

# 📊 Memory optimization for 100k+ users
# Total memory allocation ~12GB (adjust based on server RAM)
innodb_buffer_pool_size = 8G
innodb_buffer_pool_instances = 8
innodb_log_buffer_size = 256M
innodb_log_file_size = 2G
innodb_log_files_in_group = 2

# 🔄 Query cache (disabled in MySQL 8.0, using alternative optimizations)
query_cache_type = 0
query_cache_size = 0

# ⚡ Performance optimizations
tmp_table_size = 1G
max_heap_table_size = 1G
sort_buffer_size = 16M
join_buffer_size = 16M
read_buffer_size = 8M
read_rnd_buffer_size = 16M
bulk_insert_buffer_size = 64M

# 🏃‍♂️ InnoDB performance tuning
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_thread_concurrency = 0
innodb_lock_wait_timeout = 50
innodb_rollback_on_timeout = 1

# 📈 Monitoring and metrics
performance_schema = ON
slow_query_log = 1
slow_query_log_file = /var/log/mysql/mysql-slow.log
long_query_time = 2
log_queries_not_using_indexes = 1
min_examined_row_limit = 1000

# 🔒 Security optimizations
skip_name_resolve = 1
local_infile = 0

# 🌍 Timezone and SQL modes
# GALAXY: Timezone set via TZ=Europe/Rome in docker-compose.yml (auto-adjusts DST)
# default_time_zone = '+00:00'  # REMOVED: Use system timezone from container
sql_mode = 'STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO'

# 📝 Binary logging for replication (production)
server_id = 1
log_bin = mysql-bin
binlog_format = ROW
expire_logs_days = 7
max_binlog_size = 1G
sync_binlog = 1

# 🔄 Replication settings (for master-slave setup)
gtid_mode = ON
enforce_gtid_consistency = ON
binlog_checksum = CRC32
master_verify_checksum = 1
slave_sql_verify_checksum = 1

# 📊 Table and index optimizations
table_open_cache = 4096
table_definition_cache = 2048
max_allowed_packet = 1G

# 💾 Temporary files and MyISAM (legacy support)
myisam_sort_buffer_size = 128M
myisam_max_sort_file_size = 2G
myisam_repair_threads = 1

# 🔍 Full-text search optimization
ft_min_word_len = 3
ft_max_word_len = 84

[mysqldump]
quick
quote_names
max_allowed_packet = 1G

[mysql]
no_auto_rehash

[myisamchk]
key_buffer_size = 512M
sort_buffer_size = 512M
read_buffer = 8M
write_buffer = 8M

[mysqlhotcopy]
interactive_timeout